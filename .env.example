# Copy this file to .env and fill in your key(s).
#
# Reasoning backend (pick one, GROQ is the default used by reasoning/vlm_client.py)
GROQ_API_KEY=your_groq_api_key_here

# Optional alternative backends -- set VLM_BACKEND=anthropic or VLM_BACKEND=openai
# and fill in the matching key to use instead of Groq.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

VLM_BACKEND=groq
